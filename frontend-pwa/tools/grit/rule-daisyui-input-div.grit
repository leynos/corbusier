`<div className=$class>$body</div>` as $node where {
  or {
    $class <: `input`,
    $class <: `input $rest`,
    $class <: `$rest input`,
    $class <: `$pre input $post`,
  },
  register_diagnostic(span=$class, message="[daisyui/semantic-input] Apply DaisyUI 'input' to an <input>, not a <div>.")
}
