{
  "name": "@corbusier/frontend-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "audit": "bun run scripts/run-audit.mjs",
    "lint": "biome check .",
    "test:a11y": "vitest --run --config vitest.a11y.config.ts",
    "lint:classlist": "bun run scripts/check-classlist-length.ts",
    "lint:class-duplicates": "bun run scripts/find-near-duplicate-classes.ts",
    "lint:hardcoded-strings": "bun run scripts/check-hardcoded-strings.ts",
    "lint:locale-vars": "bun run scripts/check-locale-vars.ts",
    "localizability:lint": "bun run lint:hardcoded-strings && bun run lint:locale-vars",
    "semantic:lint": "bun run lint && bun run lint:classlist && bun run lint:class-duplicates && bun run lint:hardcoded-strings && uvx semgrep --config tools/semgrep-semantic.yml --include src/**/*.tsx --include tests/**/*.tsx && bunx stylelint 'src/**/*.css' --config tools/stylelint.config.cjs",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.132.41",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "overrides": {
    "@babel/core": "^7.29.1",
    "esbuild": "^0.28.1",
    "fast-uri": "3.1.2",
    "js-yaml": "^4.3.0",
    "postcss": "^8.5.13",
    "vite": "^7.3.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@testing-library/dom": "^10.4.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "axe-core": "^4.12.1",
    "daisyui": "^5.3.8",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.1",
    "stylelint": "^16.25.0",
    "stylelint-declaration-strict-value": "^1.10.11",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.3"
  }
}
