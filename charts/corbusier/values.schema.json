{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "probe": {
      "type": "object",
      "properties": {
        "httpGet": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "port": { "type": ["integer", "string"] },
            "host": { "type": "string" },
            "scheme": { "type": "string", "enum": ["HTTP", "HTTPS"] },
            "httpHeaders": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "value": { "type": "string" }
                },
                "required": ["name", "value"],
                "additionalProperties": false
              }
            }
          },
          "required": ["port"],
          "additionalProperties": false
        },
        "tcpSocket": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": ["integer", "string"] }
          },
          "required": ["port"],
          "additionalProperties": false
        },
        "exec": {
          "type": "object",
          "properties": {
            "command": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "required": ["command"],
          "additionalProperties": false
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository"],
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          },
          "additionalProperties": false
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer" },
        "maxUnavailable": { "type": "integer" }
      },
      "allOf": [
        {
          "not": {
            "required": ["minAvailable", "maxUnavailable"]
          }
        }
      ],
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "portName": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": ["integer", "string"] },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": {
                      "type": "string",
                      "enum": ["Prefix", "Exact", "ImplementationSpecific"]
                    }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["paths"]
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "secretName": { "type": "string", "minLength": 1 }
            },
            "required": ["hosts", "secretName"]
          }
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "externalSecret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshInterval": {
          "type": "string",
          "pattern": "^[0-9]+[smhd]$"
        },
        "secretStoreRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["SecretStore", "ClusterSecretStore"]
            }
          },
          "required": ["name", "kind"]
        },
        "targetName": { "type": "string" },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "secretKey": { "type": "string", "minLength": 1 },
              "remoteRef": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "key": { "type": "string", "minLength": 1 },
                  "property": { "type": "string", "minLength": 1 }
                },
                "required": ["key"]
              }
            },
            "required": ["secretKey", "remoteRef"]
          }
        }
      }
    },
    "config": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._-]{1,253}$"
      },
      "patternProperties": {
        "^[A-Za-z0-9._-]{1,253}$": {
          "type": ["string", "number", "boolean"]
        }
      },
      "additionalProperties": false
    },
    "existingSecretName": { "type": "string" },
    "secretEnvFromKeys": {
      "type": "object",
      "propertyNames": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "allowMissingSecret": { "type": "boolean", "default": true },
    "validateExistingSecret": { "type": "boolean", "default": false },
    "topologySpread": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostnamePolicy": {
          "type": "string",
          "enum": ["", "DoNotSchedule", "ScheduleAnyway"]
        }
      },
      "additionalProperties": false
    },
    "affinity": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "container": {
      "type": "object",
      "properties": {
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "startupProbe": { "$ref": "#/definitions/probe" }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "ingress": {
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      },
      "then": {
        "required": ["ingress"],
        "properties": {
          "ingress": {
            "required": ["hosts"]
          }
        }
      }
    },
    {
      "if": {
        "required": ["externalSecret"],
        "properties": {
          "externalSecret": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "externalSecret": {
            "required": ["refreshInterval", "secretStoreRef", "data"],
            "properties": {
              "refreshInterval": {
                "type": "string",
                "pattern": "^[0-9]+[smhd]$"
              },
              "secretStoreRef": {
                "properties": {
                  "name": { "type": "string", "minLength": 1 }
                }
              },
              "data": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "required": ["secretEnvFromKeys"],
            "properties": {
              "secretEnvFromKeys": { "minProperties": 1 }
            }
          },
          {
            "required": ["allowMissingSecret"],
            "properties": {
              "allowMissingSecret": { "const": false }
            }
          }
        ]
      },
      "then": {
        "anyOf": [
          {
            "required": ["existingSecretName"],
            "properties": {
              "existingSecretName": { "type": "string", "minLength": 1 }
            }
          },
          {
            "required": ["externalSecret"],
            "properties": {
              "externalSecret": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            }
          }
        ]
      }
    }
  ]
}
